# ─── Safeship environment (copy to .env and fill in) ─────────────────────────
# NOTHING here should ever contain a real secret when committed. This is a template.

# --- Database (SQLite for local dev; zero setup) ---
DATABASE_URL="file:./dev.db"

# --- Auth.js (NextAuth v5) ---
# Generate a secret with:  npx auth secret   (or)  openssl rand -base64 32
AUTH_SECRET=""
# On localhost this can be left unset; set it in production to your public URL.
# AUTH_URL="http://localhost:3000"

# --- GitHub OAuth app (free: https://github.com/settings/developers) ---
# Callback URL when creating the app: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- LLM provider (swappable) -------------------------------------------------
# One of: ollama | groq
# Default is "ollama" — fully local, free, private. Requires Ollama installed + a model pulled.
LLM_PROVIDER="ollama"

# Ollama (local). Install from https://ollama.com then: ollama pull llama3.1
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"

# Groq (free cloud API, no credit card: https://console.groq.com/keys)
# Only needed if LLM_PROVIDER=groq (recommended when deployed, since Ollama is local-only).
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# --- Security engines (optional overrides) ------------------------------------
# Leave blank to use the binary found on PATH. Set an absolute path to override.
GITLEAKS_PATH=""
SEMGREP_PATH=""
OSV_SCANNER_PATH=""

# --- Scan limits --------------------------------------------------------------
# Per-engine timeout (ms) and max findings sent to the LLM per scan.
SCAN_ENGINE_TIMEOUT_MS="120000"
SCAN_LLM_MAX_FINDINGS="40"
